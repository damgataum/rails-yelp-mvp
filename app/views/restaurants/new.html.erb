<h1>Add new restaurant</h1>
<%= simple_form_for @restaurant do |f| %>
  <%= f.input :name %>
  <%= f.input :category, collection: [ "chinese", "italian", "japanese", "french", "belgian" ] %>
  <%= f.input :address %>
  <%= f.input :phone_number %>
  <%= f.submit %>
<% end %>

<%= link_to "Back to all restaurants", restaurants_path %>
